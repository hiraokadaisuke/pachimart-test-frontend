generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("APP_DATABASE_URL")
}

enum NaviStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED

  @@map("TradeNaviStatus")
}

enum NaviType {
  PHONE_AGREEMENT
  ONLINE_INQUIRY

  @@map("TradeNaviType")
}

enum MessageSenderRole {
  buyer
  seller
}

enum DealingStatus {
  APPROVAL_REQUIRED
  PAYMENT_REQUIRED
  CONFIRM_REQUIRED
  COMPLETED
  CANCELED

  @@map("TradeStatus")
}

enum ExhibitStatus {
  DRAFT
  PUBLISHED
  SOLD

  @@map("ListingStatus")
}

enum RemovalStatus {
  REMOVED
  SCHEDULED
}

enum LedgerEntryCategory {
  PURCHASE
  SALE
  DEPOSIT
  WITHDRAWAL
}

enum LedgerEntryKind {
  PLANNED
  ACTUAL
}

enum LedgerEntrySource {
  TRADE_STATUS_TRANSITION
  MANUAL_ADJUSTMENT
}

enum ExhibitType {
  PACHINKO
  SLOT

  @@map("ListingType")
}

enum OnlineInquiryStatus {
  INQUIRY_RESPONSE_REQUIRED
  ACCEPTED
  DECLINED
  CANCELED
}

enum InventoryItemType {
  PACHINKO
  SLOT
}

enum InventoryOwnershipType {
  STOCK
  INSTALLED
  NON_STOCK
}

enum InventoryStatus {
  DRAFT
  IN_STOCK
  NEGOTIATING
  RESERVED
  OUTBOUND_SCHEDULED
  SOLD
  INSTALLED
  NON_STOCK
  ARCHIVED
}

enum InventoryListingStatus {
  NOT_LISTED
  LISTED
  NEGOTIATING
  CONTRACTED
  SUSPENDED
  CLOSED
}

enum InventoryMovementType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
  TRANSFER
}

enum InventoryMovementStatus {
  PLANNED
  COMMITTED
  CANCELED
}

enum InventoryMovementSourceType {
  MANUAL
  PURCHASE_RECORD
  SALES_RECORD
  EXHIBIT
  DEALING
  NAVI
  SEED
}

enum InboundStatus {
  PLANNED
  ARRIVAL_WAITING
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELED
}

enum OutboundStatus {
  PLANNED
  PICKING
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  CANCELED
}

enum InventoryShippingMethod {
  PREPAID
  COLLECT
  CHARTER
  OTHER
}

enum OutboundScheduleSourceType {
  MANUAL
  DEALING
  NAVI
  EXHIBIT
  ONLINE_INQUIRY
  SEED
}

enum InboundScheduleSourceType {
  MANUAL
  DEALING
  NAVI
  EXHIBIT
  ONLINE_INQUIRY
  SEED
}


enum InventoryExternalLinkType {
  EXHIBIT
  NAVI
  DEALING
  ONLINE_INQUIRY
}

enum InventoryExternalRelationRole {
  SOURCE
  DESTINATION
  RELATED
}

enum InventoryExternalSyncStatus {
  ACTIVE
  STALE
  ERROR
  CLOSED
}

enum RecordPaymentStatus {
  UNPAID
  PARTIAL
  PAID
  CANCELED
}

enum PaymentSourceType {
  PURCHASE_RECORD
  SALES_RECORD
}

enum PaymentType {
  BANK_TRANSFER
  CASH
  OFFSET
  OTHER
}

enum PaymentRecordStatus {
  PLANNED
  PAID
  CANCELED
}

enum InventoryImportStatus {
  PREVIEWED
  IMPORTED
  FAILED
  CANCELED
}


enum InventoryStocktakeStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum InventoryStocktakeMatchStatus {
  MATCHED
  QR_MATCHED
  NOT_FOUND
  DUPLICATE_SCAN
  WRONG_LOCATION
  EXPECTED_NOT_SCANNED
  MANUAL_REVIEW
}

enum InventoryStocktakeMatchedBy {
  DISPLAY_CODE
  RAW_QR
  MANUAL
}

enum InventoryUnitStatus {
  PROVISIONAL
  IN_STOCK
  RESERVED
  SHIPPED
  CANCELED
}

enum OperationCheckStatus {
  NOT_CHECKED
  OK
  NG
  NEEDS_RECHECK
}

enum UnitGlassStatus {
  UNKNOWN
  OK
  NG
  MISSING
}

enum UnitNailSheetStatus {
  UNKNOWN
  PRESENT
  MISSING
  NOT_REQUIRED
}

enum UnitInspectionStatus {
  NOT_INSPECTED
  INSPECTED
  ISSUE_FOUND
}

enum UnitDocumentStatus {
  UNKNOWN
  PRESENT
  MISSING
  NOT_REQUIRED
}


enum SalesSlipStatus {
  DRAFT
  ISSUED
  PAYMENT_PENDING
  PAID
  SHIPMENT_PENDING
  SHIPPED
  CANCELED
}

enum PartnerType {
  CUSTOMER
  SUPPLIER
  OTHER
}

enum CompanyLocationType {
  HEAD_OFFICE
  BRANCH
  WAREHOUSE
  HALL
  OTHER
}

enum TradeTermType {
  PURCHASE
  SALE
}

enum InventoryUnitCodeType {
  MAIN_BOARD
  CERTIFICATE
  BODY
  FRAME
  BOARD
  OTHER
  UNKNOWN
}

model User {
  id               String            @id
  devUserId        String?           @unique
  defaultStorageLocationId String?
  companyName      String
  contactName      String?
  address          String?
  tel              String?
  navisOwned       Navi[]            @relation("NaviOwner")
  navisBought      Navi[]            @relation("NaviBuyer")
  dealingsAsSeller Dealing[]         @relation("TradeSeller")
  dealingsAsBuyer  Dealing[]         @relation("TradeBuyer")
  messagesSent     Message[]         @relation("Sender")
  storageLocations StorageLocation[]
  inventoryItemsOwned InventoryItem[]     @relation("InventoryItemOwner")
  inventoryMovementsOwned InventoryMovement[] @relation("InventoryMovementOwner")
  inventoryMovementsCreated InventoryMovement[] @relation("InventoryMovementCreatedBy")
  inboundSchedulesOwned InboundSchedule[] @relation("InboundScheduleOwner")
  outboundSchedulesOwned OutboundSchedule[] @relation("OutboundScheduleOwner")
  inventoryUnitsOwned InventoryUnit[] @relation("InventoryUnitOwner")
  inventoryStocktakeSessions InventoryStocktakeSession[]
  inventoryStocktakeScans InventoryStocktakeScan[]
  inventoryExternalLinksOwned InventoryExternalLink[] @relation("InventoryExternalLinkOwner")
  purchaseRecordsOwned PurchaseRecord[]
  salesRecordsOwned SalesRecord[]
  paymentRecordsOwned PaymentRecord[]
  inventoryImportBatches InventoryImportBatch[]
  salesSlipsOwned SalesSlip[]
  salesSlipLinesOwned SalesSlipLine[]
  businessPartners BusinessPartner[]
  businessPartnerLocations BusinessPartnerLocation[]
  companyProfiles CompanyProfile[]
  companyLocations CompanyLocation[]
  staffMembers StaffMember[]
  bankAccounts BankAccount[]
  tradeTermTemplates TradeTermTemplate[]
  defaultStorageLocation StorageLocation? @relation("UserDefaultStorageLocation", fields: [defaultStorageLocationId], references: [id])
}


model Navi {
  id              Int        @id @default(autoincrement())
  status          NaviStatus @default(DRAFT)
  naviType        NaviType   @default(PHONE_AGREEMENT)
  ownerUserId     String
  buyerUserId     String?
  listingId       String?
  listingSnapshot Json?
  payload         Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  ownerUser User      @relation("NaviOwner", fields: [ownerUserId], references: [id])
  buyerUser User?     @relation("NaviBuyer", fields: [buyerUserId], references: [id])
  trade     Dealing?
  messages  Message[]

  @@map("Navi")
}

model Dealing {
  id           Int           @id @default(autoincrement())
  sellerUserId String
  buyerUserId  String
  status       DealingStatus
  paymentAt    DateTime?
  completedAt  DateTime?
  canceledAt   DateTime?
  payload      Json?
  naviId       Int?          @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  sellerUser User  @relation("TradeSeller", fields: [sellerUserId], references: [id])
  buyerUser  User  @relation("TradeBuyer", fields: [buyerUserId], references: [id])
  navi       Navi? @relation(fields: [naviId], references: [id])

  @@map("Dealing")
}

model Message {
  id           Int               @id @default(autoincrement())
  naviId       Int               @map("tradeNaviId")
  senderUserId String
  senderRole   MessageSenderRole
  body         String
  createdAt    DateTime          @default(now())

  senderUser User @relation("Sender", fields: [senderUserId], references: [id])
  navi       Navi @relation(fields: [naviId], references: [id])
}

model OnlineInquiry {
  id                 String              @id @default(cuid())
  listingId          String
  buyerUserId        String
  sellerUserId       String
  body               String
  buyerMemo          String?
  makerName          String?
  productName        String?
  unitPriceExclTax   Int
  quantity           Int
  taxRate            Float               @default(0.1)
  shippingFee        Int                 @default(0)
  handlingFee        Int                 @default(0)
  shippingAddress    String?
  contactPerson      String?
  desiredShipDate    String?
  desiredPaymentDate String?
  status             OnlineInquiryStatus @default(INQUIRY_RESPONSE_REQUIRED)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Exhibit {
  id                      String        @id @default(cuid())
  sellerUserId            String
  status                  ExhibitStatus @default(DRAFT)
  isVisible               Boolean       @default(true)
  type                    ExhibitType   @default(PACHINKO)
  kind                    String
  maker                   String?
  machineName             String?
  quantity                Int
  unitPriceExclTax        Int?
  isNegotiable            Boolean       @default(false)
  removalStatus           RemovalStatus @default(SCHEDULED)
  removalDate             DateTime?
  hasNailSheet            Boolean       @default(false)
  hasManual               Boolean       @default(false)
  pickupAvailable         Boolean       @default(false)
  storageLocation         String
  storageLocationId       String
  storageLocationSnapshot Json?
  shippingFeeCount        Int
  handlingFeeCount        Int
  allowPartial            Boolean
  note                    String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  storageLocationRecord StorageLocation @relation(fields: [storageLocationId], references: [id])

  @@index([sellerUserId])
  @@index([status])
  @@index([isVisible])
  @@index([updatedAt])
  @@index([storageLocationId])
  @@map("Exhibit")
}

model LedgerEntry {
  id              String             @id @default(cuid())
  userId          String
  tradeId         Int?
  category        LedgerEntryCategory
  kind            LedgerEntryKind    @default(PLANNED)
  amountYen       Int
  occurredAt      DateTime           @default(now())
  counterpartyName String?
  makerName       String?
  itemName        String?
  memo            String?
  balanceAfterYen Int?
  breakdown       Json?
  createdByUserId String
  source          LedgerEntrySource  @default(TRADE_STATUS_TRANSITION)
  tradeStatusAtCreation DealingStatus?
  dedupeKey       String             @unique

  @@index([userId, occurredAt])
  @@index([tradeId])
}

model Maker {
  id            String         @id @default(cuid())
  name          String         @unique
  machineModels MachineModel[]
  inventoryItems InventoryItem[]
}

model MachineModel {
  id      String      @id @default(cuid())
  makerId String
  type    ExhibitType
  name    String

  maker Maker @relation(fields: [makerId], references: [id])
  inventoryItems InventoryItem[]

  @@unique([makerId, type, name])
  @@index([type])
}

model StorageLocation {
  id                   String   @id @default(cuid())
  ownerUserId          String
  name                 String
  addressLine          String?  @map("address")
  postalCode           String?
  prefecture           String?
  city                 String?
  handlingFeePerUnit   Int?
  shippingFeesByRegion Json?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  ownerUser User      @relation(fields: [ownerUserId], references: [id])
  defaultForUsers User[] @relation("UserDefaultStorageLocation")
  exhibits  Exhibit[]
  inventoryItems InventoryItem[]
  inboundDestinations InboundSchedule[] @relation("InboundDestinationLocation")
  outboundOrigins OutboundSchedule[] @relation("OutboundOriginLocation")
  stocktakeTargetWarehouses InventoryStocktakeSession[] @relation("StocktakeTargetWarehouse")
  stocktakeTargetLocations InventoryStocktakeSession[] @relation("StocktakeTargetStorageLocation")
  stocktakeScansWarehouses InventoryStocktakeScan[] @relation("StocktakeScanWarehouse")
  stocktakeScansLocations InventoryStocktakeScan[] @relation("StocktakeScanStorageLocation")

  @@unique([name, ownerUserId])
  @@index([ownerUserId])
  @@index([isActive])
}

model InventoryItem {
  id                  String                 @id @default(cuid())
  ownerUserId         String
  makerId             String?
  machineModelId      String?
  makerNameSnapshot   String?
  modelNameSnapshot   String
  itemType            InventoryItemType
  frameColor          String?
  ownershipType       InventoryOwnershipType
  inventoryStatus     InventoryStatus
  quantityOnHand      Int
  storageLocationId   String?
  purchaseUnitPrice   Int?
  plannedSaleUnitPrice Int?
  listingStatus       InventoryListingStatus
  note                String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  ownerUser       User             @relation("InventoryItemOwner", fields: [ownerUserId], references: [id])
  maker           Maker?           @relation(fields: [makerId], references: [id])
  machineModel    MachineModel?    @relation(fields: [machineModelId], references: [id])
  storageLocation StorageLocation? @relation(fields: [storageLocationId], references: [id])
  movements       InventoryMovement[]
  inboundSchedules InboundSchedule[] @relation("InboundScheduleInventoryItem")
  outboundSchedules OutboundSchedule[] @relation("OutboundScheduleInventoryItem")
  inventoryUnits   InventoryUnit[]
  externalLinks    InventoryExternalLink[]
  purchaseRecords  PurchaseRecord[]
  salesRecords     SalesRecord[]
  salesSlipLines   SalesSlipLine[]
  importRows       InventoryImportRow[]

  @@index([ownerUserId, inventoryStatus, updatedAt])
  @@index([ownerUserId, listingStatus])
}

model PurchaseRecord {
  id                String            @id @default(cuid())
  ownerUserId       String
  inventoryItemId   String
  dealingId         Int?
  supplierCompanyId String?
  purchaseDate      DateTime
  unitCost          Int
  quantity          Int
  shippingCost      Int               @default(0)
  otherCost         Int               @default(0)
  totalCost         Int
  paymentStatus     RecordPaymentStatus @default(UNPAID)
  memo              String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  ownerUser      User          @relation(fields: [ownerUserId], references: [id])
  inventoryItem  InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([ownerUserId, purchaseDate])
  @@index([inventoryItemId, purchaseDate])
}

model SalesRecord {
  id              String              @id @default(cuid())
  ownerUserId     String
  inventoryItemId String
  dealingId       Int?
  buyerCompanyId  String?
  salesDate       DateTime
  unitPrice       Int
  quantity        Int
  shippingFee     Int                 @default(0)
  platformFee     Int                 @default(0)
  otherFee        Int                 @default(0)
  totalSales      Int
  paymentStatus   RecordPaymentStatus @default(UNPAID)
  memo            String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  ownerUser      User          @relation(fields: [ownerUserId], references: [id])
  inventoryItem  InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([ownerUserId, salesDate])
  @@index([inventoryItemId, salesDate])
}

model PaymentRecord {
  id          String              @id @default(cuid())
  ownerUserId String
  sourceType  PaymentSourceType
  sourceId    String
  paymentType PaymentType
  amount      Int
  paidAt      DateTime?
  status      PaymentRecordStatus
  memo        String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  ownerUser   User                @relation(fields: [ownerUserId], references: [id])

  @@index([ownerUserId, createdAt])
  @@index([sourceType, sourceId])
}


model InventoryExternalLink {
  id              String                        @id @default(cuid())
  ownerUserId     String
  inventoryItemId String
  linkType        InventoryExternalLinkType
  externalId      String
  relationRole    InventoryExternalRelationRole
  syncStatus      InventoryExternalSyncStatus
  payloadSnapshot Json?
  syncedAt        DateTime?
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt

  ownerUser     User          @relation("InventoryExternalLinkOwner", fields: [ownerUserId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@unique([ownerUserId, linkType, externalId, relationRole])
  @@index([inventoryItemId, linkType])
  @@index([ownerUserId, syncStatus])
}

model InboundSchedule {
  id                    String            @id @default(cuid())
  ownerUserId           String
  inventoryItemId       String?
  expectedDate          DateTime
  supplierName          String?
  itemType              InventoryItemType
  makerNameSnapshot     String?
  modelNameSnapshot     String
  frameColor            String?
  quantity              Int
  destinationLocationId String?
  status                InboundStatus
  sourceType            InboundScheduleSourceType?
  sourceId              String?
  dedupeKey             String?                  @unique
  note                  String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  ownerUser User @relation("InboundScheduleOwner", fields: [ownerUserId], references: [id])
  inventoryItem InventoryItem? @relation("InboundScheduleInventoryItem", fields: [inventoryItemId], references: [id])
  destinationLocation StorageLocation? @relation("InboundDestinationLocation", fields: [destinationLocationId], references: [id])
  inventoryUnits InventoryUnit[]

  @@index([ownerUserId, status, expectedDate])
  @@index([inventoryItemId, expectedDate])
  @@index([ownerUserId, sourceType, sourceId])
}

model OutboundSchedule {
  id               String                  @id @default(cuid())
  ownerUserId      String
  inventoryItemId  String?
  expectedDate     DateTime
  buyerName        String?
  itemType         InventoryItemType
  makerNameSnapshot String?
  modelNameSnapshot String
  frameColor       String?
  quantity         Int
  originLocationId String?
  shippingMethod   InventoryShippingMethod
  status           OutboundStatus
  sourceType       OutboundScheduleSourceType?
  sourceId         String?
  dedupeKey        String?                 @unique
  note             String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  ownerUser User @relation("OutboundScheduleOwner", fields: [ownerUserId], references: [id])
  inventoryItem InventoryItem? @relation("OutboundScheduleInventoryItem", fields: [inventoryItemId], references: [id])
  originLocation StorageLocation? @relation("OutboundOriginLocation", fields: [originLocationId], references: [id])
  inventoryUnits InventoryUnit[]

  @@index([ownerUserId, status, expectedDate])
  @@index([inventoryItemId, expectedDate])
  @@index([ownerUserId, sourceType, sourceId])
}

model InventoryUnit {
  id                String                 @id @default(cuid())
  ownerUserId       String
  inventoryItemId   String
  displayCode       String?
  rawQr             String?
  parsedQr          Json?
  codeType          InventoryUnitCodeType?
  bodySerialNumber  String?
  frameSerialNumber String?
  mainBoardSerialNumber String?
  subBoardSerialNumber String?
  certificateNumber String?
  operationCheckStatus OperationCheckStatus? @default(NOT_CHECKED)
  operationCheckedAt DateTime?
  operationMemo     String?
  glassStatus       UnitGlassStatus? @default(UNKNOWN)
  nailSheetStatus   UnitNailSheetStatus? @default(UNKNOWN)
  accessoryMemo     String?
  inspectionStatus  UnitInspectionStatus? @default(NOT_INSPECTED)
  inspectedAt       DateTime?
  inspectionMemo    String?
  inspectionDocumentStatus UnitDocumentStatus? @default(UNKNOWN)
  certificateDocumentStatus UnitDocumentStatus? @default(UNKNOWN)
  itemType          InventoryItemType
  status            InventoryUnitStatus    @default(PROVISIONAL)
  storageLocationId String?
  inboundScheduleId String?
  outboundScheduleId String?
  purchaseRecordId  String?
  salesRecordId     String?
  memo              String?
  confirmedAt       DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  ownerUser         User                   @relation("InventoryUnitOwner", fields: [ownerUserId], references: [id])
  inventoryItem     InventoryItem          @relation(fields: [inventoryItemId], references: [id])
  inboundSchedule   InboundSchedule?       @relation(fields: [inboundScheduleId], references: [id])
  outboundSchedule  OutboundSchedule?      @relation(fields: [outboundScheduleId], references: [id])
  salesSlipLines   SalesSlipLine[]
  stocktakeScans   InventoryStocktakeScan[]

  @@index([ownerUserId, displayCode])
  @@index([inventoryItemId, status])
  @@index([inboundScheduleId])
  @@index([outboundScheduleId])
}

model InventoryMovement {
  id              String                      @id @default(cuid())
  ownerUserId     String
  inventoryItemId String
  movementType    InventoryMovementType
  status          InventoryMovementStatus
  quantityDelta   Int
  scheduledAt     DateTime?
  committedAt     DateTime?
  sourceType      InventoryMovementSourceType?
  sourceId        String?
  dedupeKey       String?                     @unique
  note            String?
  createdByUserId String?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  ownerUser     User          @relation("InventoryMovementOwner", fields: [ownerUserId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  createdByUser User?         @relation("InventoryMovementCreatedBy", fields: [createdByUserId], references: [id])

  @@index([inventoryItemId, committedAt])
  @@index([ownerUserId, status, createdAt])
  @@index([sourceType, sourceId])
}


model InventoryStocktakeSession {
  id                      String                   @id @default(cuid())
  ownerUserId             String
  name                    String
  status                  InventoryStocktakeStatus @default(DRAFT)
  targetWarehouseId       String?
  targetStorageLocationId String?
  startedAt               DateTime?
  completedAt             DateTime?
  memo                    String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  ownerUser            User              @relation(fields: [ownerUserId], references: [id])
  targetWarehouse      StorageLocation?  @relation("StocktakeTargetWarehouse", fields: [targetWarehouseId], references: [id])
  targetStorageLocation StorageLocation? @relation("StocktakeTargetStorageLocation", fields: [targetStorageLocationId], references: [id])
  scans                InventoryStocktakeScan[]

  @@index([ownerUserId])
  @@index([status, createdAt])
  @@index([targetWarehouseId])
  @@index([targetStorageLocationId])
}

model InventoryStocktakeScan {
  id                    String                         @id @default(cuid())
  ownerUserId           String
  sessionId             String
  inventoryUnitId       String?
  scannedRawQr          String?
  scannedDisplayCode    String?
  normalizedDisplayCode String?
  matchStatus           InventoryStocktakeMatchStatus
  matchedBy             InventoryStocktakeMatchedBy?
  warehouseId           String?
  storageLocationId     String?
  scannedAt             DateTime                       @default(now())
  memo                  String?
  createdAt             DateTime                       @default(now())

  ownerUser        User                     @relation(fields: [ownerUserId], references: [id])
  session          InventoryStocktakeSession @relation(fields: [sessionId], references: [id])
  inventoryUnit    InventoryUnit?            @relation(fields: [inventoryUnitId], references: [id])
  warehouse        StorageLocation?          @relation("StocktakeScanWarehouse", fields: [warehouseId], references: [id])
  storageLocation  StorageLocation?          @relation("StocktakeScanStorageLocation", fields: [storageLocationId], references: [id])

  @@index([ownerUserId])
  @@index([sessionId])
  @@index([inventoryUnitId])
  @@index([normalizedDisplayCode])
}

model InventoryImportBatch {
  id          String                @id @default(cuid())
  ownerUserId String
  fileName    String
  fileHash    String?
  totalRows   Int
  successRows Int                   @default(0)
  errorRows   Int                   @default(0)
  status      InventoryImportStatus @default(PREVIEWED)
  memo        String?
  createdAt   DateTime              @default(now())
  completedAt DateTime?

  ownerUser User                 @relation(fields: [ownerUserId], references: [id])
  rows      InventoryImportRow[]

  @@index([ownerUserId, createdAt])
  @@index([ownerUserId, fileHash, status])
}

model InventoryImportRow {
  id              String                @id @default(cuid())
  batchId         String
  rowNumber       Int
  status          InventoryImportStatus
  errorMessage    String?
  rawData         Json
  inventoryItemId String?
  createdAt       DateTime              @default(now())

  batch         InventoryImportBatch @relation(fields: [batchId], references: [id])
  inventoryItem InventoryItem?       @relation(fields: [inventoryItemId], references: [id])

  @@index([batchId, rowNumber])
  @@index([inventoryItemId])
}

model BuyerShippingAddress {
  id          String   @id @default(cuid())
  ownerUserId String
  label       String?
  companyName String?
  postalCode  String?
  prefecture  String?
  city        String?
  addressLine String?
  tel         String?
  contactName String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerUserId, isActive])
}


model SalesSlip {
  id                 String          @id @default(cuid())
  ownerUserId        String
  slipNumber         String?
  customerId         String?
  customerName       String
  salesContactName   String?
  status             SalesSlipStatus @default(DRAFT)
  contractedAt       DateTime?
  paymentDueDate     DateTime?
  paymentTimeText    String?
  paymentMethod      String?
  bankAccountId      String?
  shippingMethod     String?
  machineShipDate    DateTime?
  documentShipDate   DateTime?
  destinationName    String?
  destinationAddress String?
  destinationPhone   String?
  carrierName        String?
  sharedShippingNote String?
  subtotalAmount     Int             @default(0)
  taxAmount          Int             @default(0)
  totalAmount        Int             @default(0)
  grossProfitAmount  Int             @default(0)
  memo               String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  ownerUser   User            @relation(fields: [ownerUserId], references: [id])
  bankAccount BankAccount?    @relation(fields: [bankAccountId], references: [id])
  lines       SalesSlipLine[]

  @@index([ownerUserId, createdAt])
}

model SalesSlipLine {
  id                  String   @id @default(cuid())
  ownerUserId         String
  salesSlipId         String
  inventoryItemId     String?
  inventoryUnitId     String?
  makerName           String?
  machineName         String
  itemType            InventoryItemType
  quantity            Int      @default(1)
  purchaseUnitPrice   Int?
  salesUnitPrice      Int
  amount              Int
  nailSheet           Boolean  @default(false)
  frameColor          String?
  storageLocationName String?
  memo                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  ownerUser      User          @relation(fields: [ownerUserId], references: [id])
  salesSlip      SalesSlip     @relation(fields: [salesSlipId], references: [id])
  inventoryItem  InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  inventoryUnit  InventoryUnit? @relation(fields: [inventoryUnitId], references: [id])

  @@index([ownerUserId])
  @@index([salesSlipId])
}

model BusinessPartner {
  id                 String      @id @default(cuid())
  ownerUserId        String
  type               PartnerType
  name               String
  postalCode         String?
  address            String?
  representativeName String?
  phone              String?
  fax                String?
  invoiceNumber      String?
  email              String?
  memo               String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  ownerUser          User        @relation(fields: [ownerUserId], references: [id])
  locations          BusinessPartnerLocation[]
  @@index([ownerUserId])
}

model BusinessPartnerLocation {
  id          String   @id @default(cuid())
  ownerUserId String
  partnerId   String
  name        String
  postalCode  String?
  address     String?
  phone       String?
  fax         String?
  memo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ownerUser   User     @relation(fields: [ownerUserId], references: [id])
  partner     BusinessPartner @relation(fields: [partnerId], references: [id])
  @@index([ownerUserId])
  @@index([partnerId])
}

model CompanyProfile {
  id                 String   @id @default(cuid())
  ownerUserId        String
  name               String
  postalCode         String?
  address            String?
  representativeName String?
  phone              String?
  fax                String?
  registrationNumber String?
  invoiceNumber      String?
  email              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  ownerUser          User     @relation(fields: [ownerUserId], references: [id])
  locations          CompanyLocation[]
  @@index([ownerUserId])
}

model CompanyLocation {
  id               String   @id @default(cuid())
  ownerUserId      String
  companyProfileId String?
  name             String
  type             CompanyLocationType
  postalCode       String?
  address          String?
  phone            String?
  fax              String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  ownerUser        User     @relation(fields: [ownerUserId], references: [id])
  companyProfile   CompanyProfile? @relation(fields: [companyProfileId], references: [id])
  staffMembers     StaffMember[]
  @@index([ownerUserId])
}

model StaffMember {
  id                String   @id @default(cuid())
  ownerUserId       String
  companyLocationId String?
  name              String
  role              String?
  phone             String?
  email             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  ownerUser         User     @relation(fields: [ownerUserId], references: [id])
  companyLocation   CompanyLocation? @relation(fields: [companyLocationId], references: [id])
  @@index([ownerUserId])
}

model BankAccount {
  id            String   @id @default(cuid())
  ownerUserId   String
  bankCode      String?
  bankName      String
  branchCode    String?
  branchName    String?
  accountType   String?
  accountNumber String
  accountHolder String
  subjectCode   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  ownerUser     User     @relation(fields: [ownerUserId], references: [id])
  salesSlips    SalesSlip[]
  @@index([ownerUserId])
}

model TradeTermTemplate {
  id          String        @id @default(cuid())
  ownerUserId String
  type        TradeTermType
  title       String
  body        String
  isDefault   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  ownerUser   User          @relation(fields: [ownerUserId], references: [id])
  @@index([ownerUserId, type])
}
